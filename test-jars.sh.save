#!/bin/bash

# 색상 정의
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 로그 보기 함수
show_logs() {
    local service_dir=$1
    local lines=${2:-50}  # 기본값 50줄
    local log_file="$service_dir/logs/spring.log"
    
    if [ -f "$log_file" ]; then
        echo -e "${YELLOW}Last $lines lines of $service_dir logs:${NC}"
        tail -n $lines "$log_file"
    else
        echo -e "${RED}No log file found for $service_dir${NC}"
    fi
}

# 메인 로직
if [ "$1" = "logs" ]; then
    # 로그 보기 모드
    if [ -n "$2" ]; then
        show_logs "$2" "${3:-50}"
        exit 0
    else
        echo "Usage: ./test-jars.sh logs [service-name] [number-of-lines]"
        echo "Example: ./test-jars.sh logs eureka-service 50"
        exit 1
    fi
fi

# 여기서부터 서비스 시작 로직
# 포트 킬 함수
kill_port() {
    local port=$1
    local pid=$(lsof -ti:$port)
    if [ ! -z "$pid" ]; then
        echo -e "${YELLOW}Killing process on port $port (PID: $pid)${NC}"
        kill -9 $pid
        sleep 2
    fi
}

# 서비스 실행 함수
run_service() {
    local service_dir=$1
    local port=$2
    
    echo -e "\n${YELLOW}Starting $service_dir on port $port...${NC}"
    
    # 포트 사용중이면 종료
    kill_port $port
    
    # JAR 파일 찾기
    local jar_file=$(find "${service_dir}build/libs" -name "*.jar" -not -name "*plain.jar" -type f | head -n 1)
    
    if [ -n "$jar_file" ]; then
        echo "Running $jar_file"
        mkdir -p "$service_dir/logs"
        java -jar "$jar_file" --server.port=$port > "$service_dir/logs/spring.log" 2>&1 &
        
        # 시작 확인
        sleep 5
        if lsof -i:$port > /dev/null; then
            echo -e "${GREEN}✓ $service_dir successfully started on port $port${NC}"
            show_logs $service_dir 10  # 마지막 10줄만 표시
        else
            echo -e "${RED}✗ $service_dir failed to start${NC}"
            show_logs $service_dir 20  # 오류 시 20줄 표시
        fi
    e        echo -e "${RED}✗ No executable jar file found in $service_dir${NC}"
    fi
}

# 모든 서비스 종료
kill_all_services() {
    echo -e "${YELLOW}Shutting down all services...${NC}"
    jps | grep -v "Jps" | awk '{print $1}' | xargs -r kill -9
    sleep 2
    echo -e "${GREEN}All services stopped${NC}"
}

# Ctrl+C 처리
trap 'kill_all_services; exit' INT

# 시작 전 모든 서비스 종료
kill_all_services

echo -e "${YELLOW}Starting services in order...${NC}"

# 서비스 순차적 실행
run_service "eureka-service/" "8761"
sleep 5  # Eureka 서버 시작 대기

run_service "apigateway-service/" "8080"
sleep 3

run_service "content-service/" "8083"
run_service "auth-service/" "9000"
run_service "member-service/" "9001"
run_service "subscribe-service/" "9005"
run_service "ad-service/" "9003"
run_service "ad-admin-service/" "8089"
run_service "userAction-test-service/" "8085"
run_service "review-service/" "9007"
run_service "UI-service/" "9002"

echo -e "\n${GREEN}All services started. Current running services:${NC}"
jps -l

echo -e "\n${YELLOW}To view logs for a specific service:${NC}"
echo "./test-jars.sh logs [service-name] [number-of-lines]"
echo "Example: ./test-jars.sh logs eureka-service 50"

echo -e "${YELLOW}Press Ctrl+C to stop all services${NC}"
wait
